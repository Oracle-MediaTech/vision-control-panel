{
  "name": "vision-control-panel",
  "version": "1.0.0",
  "description": "Control panel for Vision Church management system",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc && vite build",
    "build:main": "tsc",
    "build:renderer": "vite build",
    "start": "npm run build && electron .",
    "dev": "npm run build && concurrently -k \"tsc --watch\" \"vite build --watch\" \"electronmon .\"",
    "prepackage:backend": "node scripts/stage-backend.js",
    "prepare:runtime": "node scripts/prepare-runtime.js",
    "pack": "npm run build && npm run prepackage:backend && electron-builder --dir",
    "dist": "npm run prepare:runtime && npm run build && npm run prepackage:backend && electron-builder"
  },
  "build": {
    "appId": "com.vision.control-panel",
    "productName": "Vision Control Panel",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "renderer/dist/**/*",
      "preload.js"
    ],
    "extraResources": [
      {
    "from": "node-runtime/node.exe",
    "to": "node/node.exe"
  },
  {
    "from": "node-runtime/package.json",
    "to": "node/package.json"
  },
  {
    "from": "node-runtime/package-lock.json",
    "to": "node/package-lock.json"
  },
  {
    "from": "node-runtime/node_modules",
    "to": "node/node_modules",
    "filter": [
      "**/*"
    ]
  },
      {
        "from": "ecosystem.config.js",
        "to": "ecosystem.config.js"
      },
      {
        "from": "../vfc-backend/.stage",
        "to": "backend"
      },
      {
        "from": "../vfc-backend/node_modules",
        "to": "backend/node_modules"
      },
      {
        "from": "../vfc-backend/package.json",
        "to": "backend/package.json"
      }
    ],
    "win": {
      "target": "nsis",
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "electronmon": {
    "patterns": [
      "dist/**/*"
    ],
    "logLevel": "quiet"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "pg": "^8.11.0",
    "pm2": "^5.4.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^35.0.0",
    "electron-builder": "^26.8.1",
    "electronmon": "^2.0.4",
    "fs-extra": "^11.3.6",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.12"
  }
}